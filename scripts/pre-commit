#!/usr/bin/env bash
# TurboAPI pre-commit hook
# Runs: 1) ruff lint  2) zig build check  3) unit tests  4) smoke test
# Install: make hooks
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
PASS=true

# ── Detect Python ─────────────────────────────────────────────────────────────

if [ -x "$ROOT/.venv314t/bin/python" ]; then
    PYTHON="$ROOT/.venv314t/bin/python"
elif [ -x "$ROOT/.venv/bin/python" ]; then
    PYTHON="$ROOT/.venv/bin/python"
elif [ -n "${VIRTUAL_ENV:-}" ]; then
    PYTHON="$VIRTUAL_ENV/bin/python"
else
    PYTHON="$(command -v python3 || command -v python)"
fi

# ── Collect staged files ─────────────────────────────────────────────────────

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' || true)
STAGED_ZIG=$(git diff --cached --name-only --diff-filter=ACM -- '*.zig' || true)

# ── 1. Python: ruff lint ─────────────────────────────────────────────────────

if [ -n "$STAGED_PY" ]; then
    echo "🐍 Checking Python files..."

    if command -v ruff &>/dev/null; then
        RUFF=ruff
    elif [ -x "$ROOT/.venv314t/bin/ruff" ]; then
        RUFF="$ROOT/.venv314t/bin/ruff"
    elif [ -x "$ROOT/.venv/bin/ruff" ]; then
        RUFF="$ROOT/.venv/bin/ruff"
    else
        echo "   ⚠️  ruff not found, skipping Python lint"
        RUFF=""
    fi

    if [ -n "$RUFF" ]; then
        if ! $RUFF check --no-fix --config "$ROOT/pyproject.toml" $STAGED_PY 2>/dev/null; then
            echo "   ❌ ruff lint failed — run 'make lint' to see details, 'make fmt' to auto-fix"
            PASS=false
        else
            echo "   ✅ ruff lint passed"
        fi
    fi
fi

# ── 2. Zig: compile check ───────────────────────────────────────────────────

if [ -n "$STAGED_ZIG" ]; then
    echo "⚡ Checking Zig files..."

    if ! "$ROOT/scripts/build.sh" --check >/dev/null 2>&1; then
        echo "   ❌ Zig build failed — run 'make build' to see errors"
        PASS=false
    else
        echo "   ✅ Zig build passed"
    fi
fi

# ── 3. Unit tests (fast, no DB needed) ──────────────────────────────────────

if [ -n "$STAGED_PY" ]; then
    echo "🧪 Running unit tests..."

    # TurboPG tests (17 tests, 0.02s, no DB)
    if PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 $PYTHON -m pytest "$ROOT/tests/test_turbopg.py" -q --no-header 2>/dev/null; then
        echo "   ✅ TurboPG tests passed"
    else
        echo "   ❌ TurboPG tests failed"
        PASS=false
    fi

    # Annotated Depends tests (7 tests, 0.07s, no DB)
    if PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 $PYTHON -m pytest "$ROOT/tests/test_annotated_depends.py" -q --no-header 2>/dev/null; then
        echo "   ✅ Annotated Depends tests passed"
    else
        echo "   ❌ Annotated Depends tests failed"
        PASS=false
    fi

    # Security audit tests (12 tests, 0.09s, no DB)
    if PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 $PYTHON -m pytest "$ROOT/tests/test_security_audit_fixes.py" -q --no-header 2>/dev/null; then
        echo "   ✅ Security tests passed"
    else
        echo "   ❌ Security tests failed"
        PASS=false
    fi
fi

# ── 4. Smoke test ────────────────────────────────────────────────────────────

if [ -n "$STAGED_ZIG" ] && [ -n "$STAGED_PY" ]; then
    echo "🔌 Running smoke test..."

    if $PYTHON -c "from turboapi import TurboAPI; print('   ✅ Import check passed')" 2>/dev/null; then
        :
    else
        echo "   ⚠️  Import check skipped (turbonet may not be built for this Python)"
    fi
fi

# ── Result ───────────────────────────────────────────────────────────────────

if ! $PASS; then
    echo ""
    echo "❌ Pre-commit checks failed. Fix the issues above, then 'git add' and retry."
    exit 1
fi

echo "✅ All pre-commit checks passed"
